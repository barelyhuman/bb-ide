{
  "name": "@bb/agent-runtime",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./capture": {
      "types": "./dist/capture.d.ts",
      "import": "./dist/capture.js"
    },
    "./shared/json-rpc-envelope": {
      "types": "./dist/shared/json-rpc-envelope.d.ts",
      "import": "./dist/shared/json-rpc-envelope.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "import": "./dist/test/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts --exclude '**/integration/**'",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "@bb/agent-providers": "workspace:*",
    "@bb/domain": "workspace:*",
    "@bb/process-utils": "workspace:*",
    "@mariozechner/pi-ai": "^0.70.5",
    "@mariozechner/pi-coding-agent": "^0.70.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bb/test-helpers": "workspace:*",
    "@bb/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
