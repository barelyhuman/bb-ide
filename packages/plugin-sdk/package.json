{
  "name": "@bb/plugin-sdk",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./app": {
      "source": "./src/app.ts",
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "node scripts/build-bundled-dts.mjs",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "node scripts/build-bundled-dts.mjs --check && tsc --noEmit"
  },
  "devDependencies": {
    "@bb/domain": "workspace:*",
    "@bb/sdk": "workspace:*",
    "@bb/server-contract": "workspace:*",
    "@bb/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "better-sqlite3": "12.10.0",
    "hono": "4.11.9",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.7.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.0",
    "better-sqlite3": ">=12",
    "hono": "^4.11.9",
    "react": "^19.0.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "@types/better-sqlite3": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
