{
  "name": "@bb/config",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./server-port": {
      "types": "./dist/server-port.d.ts",
      "import": "./dist/server-port.js"
    },
    "./dev-env": {
      "types": "./dist/dev-env.d.ts",
      "import": "./dist/dev-env.js"
    },
    "./host-daemon": {
      "types": "./dist/host-daemon.d.ts",
      "import": "./dist/host-daemon.js"
    },
    "./host-daemon-entrypoint": {
      "types": "./dist/host-daemon-entrypoint.d.ts",
      "import": "./dist/host-daemon-entrypoint.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "import": "./dist/defaults.js"
    },
    "./database": {
      "types": "./dist/database.d.ts",
      "import": "./dist/database.js"
    },
    "./data-dir": {
      "types": "./dist/data-dir.d.ts",
      "import": "./dist/data-dir.js"
    },
    "./strings": {
      "types": "./dist/strings.d.ts",
      "import": "./dist/strings.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
