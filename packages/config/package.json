    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@bb/domain": "workspace:*",
    "envsafe": "^2.0.3"
  },
  "devDependencies": {
    "@bb/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
