{
  "name": "@bb/scripts",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./lib/run-dev-supervisor": {
      "source": "./src/lib/run-dev-supervisor.ts",
      "types": "./src/lib/run-dev-supervisor.ts",
      "import": "./dist/lib/run-dev-supervisor.js"
    },
    "./request-dev-restart": {
      "source": "./src/commands/request-dev-restart.ts",
      "types": "./src/commands/request-dev-restart.ts",
      "import": "./dist/commands/request-dev-restart.js"
    },
    "./run-worktree-dev": {
      "source": "./src/commands/run-worktree-dev.ts",
      "types": "./src/commands/run-worktree-dev.ts",
      "import": "./dist/commands/run-worktree-dev.js"
    },
    "./run-cli": {
      "source": "./src/commands/run-cli.ts",
      "types": "./src/commands/run-cli.ts",
      "import": "./dist/commands/run-cli.js"
    },
    "./run-host-daemon": {
      "source": "./src/commands/run-host-daemon.ts",
      "types": "./src/commands/run-host-daemon.ts",
      "import": "./dist/commands/run-host-daemon.js"
    },
    "./reset-bb-data": {
      "source": "./src/commands/reset-bb-data.ts",
      "types": "./src/commands/reset-bb-data.ts",
      "import": "./dist/commands/reset-bb-data.js"
    },
    "./archive-codex-tmp-bb-sessions": {
      "source": "./src/commands/archive-codex-tmp-bb-sessions.ts",
      "types": "./src/commands/archive-codex-tmp-bb-sessions.ts",
      "import": "./dist/commands/archive-codex-tmp-bb-sessions.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "cli": "node dist/commands/run-cli.js",
    "dev:host-daemon": "node dist/commands/run-host-daemon.js --auto-join",
    "dev:restart": "node dist/commands/request-dev-restart.js both",
    "dev:restart-host-daemon": "node dist/commands/request-dev-restart.js host-daemon",
    "dev:restart-server": "node dist/commands/request-dev-restart.js server",
    "dev:worktree": "node dist/commands/run-worktree-dev.js",
    "reset": "node dist/commands/reset-bb-data.js",
    "codex:archive-tmp-bb-sessions": "node dist/commands/archive-codex-tmp-bb-sessions.js"
  },
  "dependencies": {
    "@bb/config": "workspace:*",
    "@bb/host-daemon-contract": "workspace:*",
    "@bb/process-utils": "workspace:*",
    "@bb/server-contract": "workspace:*",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@bb/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
