{
  "name": "@bb/scripts",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./lib/run-dev-supervisor": {
      "types": "./dist/lib/run-dev-supervisor.d.ts",
      "import": "./dist/lib/run-dev-supervisor.js"
    },
    "./request-dev-restart": {
      "types": "./dist/commands/request-dev-restart.d.ts",
      "import": "./dist/commands/request-dev-restart.js"
    },
    "./run-cli": {
      "types": "./dist/commands/run-cli.d.ts",
      "import": "./dist/commands/run-cli.js"
    },
    "./run-host-daemon": {
      "types": "./dist/commands/run-host-daemon.d.ts",
      "import": "./dist/commands/run-host-daemon.js"
    },
    "./start-bb": {
      "types": "./dist/commands/start-bb.d.ts",
      "import": "./dist/commands/start-bb.js"
    },
    "./start-host-daemon": {
      "types": "./dist/commands/start-host-daemon.d.ts",
      "import": "./dist/commands/start-host-daemon.js"
    },
    "./reset-bb-data": {
      "types": "./dist/commands/reset-bb-data.d.ts",
      "import": "./dist/commands/reset-bb-data.js"
    },
    "./archive-codex-tmp-bb-sessions": {
      "types": "./dist/commands/archive-codex-tmp-bb-sessions.d.ts",
      "import": "./dist/commands/archive-codex-tmp-bb-sessions.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "cli": "node dist/commands/run-cli.js",
    "dev:host-daemon": "node dist/commands/run-host-daemon.js --auto-join",
    "dev:restart": "node dist/commands/request-dev-restart.js both",
    "dev:restart-host-daemon": "node dist/commands/request-dev-restart.js host-daemon",
    "dev:restart-server": "node dist/commands/request-dev-restart.js server",
    "reset": "node dist/commands/reset-bb-data.js",
    "codex:archive-tmp-bb-sessions": "node dist/commands/archive-codex-tmp-bb-sessions.js",
    "start": "node dist/commands/start-bb.js",
    "start:host-daemon": "node dist/commands/start-host-daemon.js"
  },
  "dependencies": {
    "@bb/config": "workspace:*",
    "@bb/host-daemon-contract": "workspace:*",
    "@bb/process-utils": "workspace:*",
    "@bb/server-contract": "workspace:*",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@bb/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
