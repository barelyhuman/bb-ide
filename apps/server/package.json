{
  "name": "@bb/server",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node ../../scripts/build-node-entry.mjs src/index.ts dist/index.js --clean-dist --templates --external ./start-server.js --copy-dir ../../packages/db/drizzle dist/drizzle && node --import tsx scripts/copy-builtin-skills.ts && node ../../scripts/build-node-entry.mjs src/start-server.ts dist/start-server.js",
    "start": "node dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "dev": "node --conditions=source --import tsx scripts/dev-supervisor.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@bb/agent-providers": "workspace:*",
    "@bb/config": "workspace:*",
    "@bb/core-ui": "workspace:*",
    "@bb/db": "workspace:*",
    "@bb/domain": "workspace:*",
    "@bb/host-daemon-contract": "workspace:*",
    "@bb/logger": "workspace:*",
    "@bb/process-utils": "workspace:*",
    "@bb/secret-storage": "workspace:*",
    "@bb/server-contract": "workspace:*",
    "@bb/templates": "workspace:*",
    "@bb/thread-view": "workspace:*",
    "@better-auth/api-key": "^1.5.6",
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@mariozechner/pi-ai": "^0.70.5",
    "better-auth": "^1.5.6",
    "better-sqlite3": "12.10.0",
    "drizzle-orm": "^0.38.4",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.0",
    "mime-types": "^3.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "pino-roll": "^4.0.0",
    "semver": "^7.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bb/scripts": "workspace:*",
    "@bb/test-helpers": "workspace:*",
    "@bb/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1",
    "ws": "^8.19.0"
  }
}
