# Copy this file to .env and uncomment only the values you need to override.

# Runtime state. Defaults:
# - pnpm start: ~/.bb
# - pnpm dev: ~/.bb-dev/<checkout-instance>
# BB_DATA_DIR=~/.bb

# Optional override for the server/daemon thread-storage root.
# Agents also receive BB_THREAD_STORAGE as the current thread's storage path.
# BB_THREAD_STORAGE=~/.bb/thread-storage

# Production-mode ports used by pnpm start.
# BB_SERVER_PORT=38886
# BB_HOST_DAEMON_PORT=38887

# Human-facing app URL for generated links and allowed browser origins.
# Leave empty for local-only use.
# BB_APP_URL=

# Server-side helper inference and voice transcription routes.
# Defaults piggyback on Codex CLI auth from the host daemon.
# BB_INFERENCE=codex/gpt-5.4-mini
# BB_TRANSCRIPTION=codex/gpt-4o-mini-transcribe

# Explicit OpenAI provider routes are opt-in source-development overrides.
# Store packaged-app provider credentials with `bb-app env set ...`.
# BB_INFERENCE=openai/gpt-4o-mini
# BB_TRANSCRIPTION=openai/gpt-4o-transcribe
