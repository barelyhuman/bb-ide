{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "BB_RUNTIME_MODE",
        "BB_ROOT",
        "BB_SERVER_PORT",
        "BB_APP_PORT",
        "BB_PROVIDER",
        "BB_DEFAULT_PROVIDER"
      ]
    },
    "clean": {
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build", "^build"]
    },
    "test:integration": {
      "dependsOn": ["build", "^build"]
    },
    "test:e2e": {
      "dependsOn": ["build", "^build"]
    }
  }
}
