# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# testing
/coverage

# next.js
.next
dist
out

# production
/build
/apps/app/build/
/packages/bb-app/host-daemon/
/apps/desktop/release/
/apps/desktop/.electron-builder.generated.json

# generated at build time (see @bb/sdk#generate:app-runtime-browser-bundle)
/packages/sdk/src/app-runtime-browser-bundle.generated.ts

# misc
.DS_Store
*.pem

# temporary scripts
.tmp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.dev.vars
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/data/
output.txt

# codex, claude code
.claude/settings.local.json
.codex
.hermes/plans/

# turborepo
.turbo
.claude/
