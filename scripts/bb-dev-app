#!/bin/zsh
set -euo pipefail

script_dir="${0:A:h}"
REPO_ROOT="${BB_DEV_REPO_ROOT:-${script_dir:h}}"

if [[ -n "${BB_DEV_NODE_BIN_DIR:-}" ]]; then
  PATH="${BB_DEV_NODE_BIN_DIR}:${HOME}/.local/bin:${PATH}"
else
  PATH="${HOME}/.local/bin:${PATH}"
fi

sanitize_label() {
  print -r -- "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9._-]+/-/g; s/^[._-]+//; s/[._-]+$//'
}

repo_label="${REPO_ROOT#$HOME/}"
if [[ "${repo_label}" == "${REPO_ROOT}" ]]; then
  repo_label="${REPO_ROOT}"
fi

LAUNCHER_NAME="${BB_DEV_LAUNCHER_NAME:-$(sanitize_label "${repo_label}")}"
if [[ -z "${LAUNCHER_NAME}" ]]; then
  LAUNCHER_NAME="bb"
fi

DEV_SESSION="bb-dev-app-${LAUNCHER_NAME}-dev"
DESKTOP_SESSION="bb-dev-app-${LAUNCHER_NAME}-desktop"
LOG_ROOT="${HOME}/.bb-dev/launchers/${LAUNCHER_NAME}"
DEV_LOG="${LOG_ROOT}/dev.log"
DESKTOP_LOG="${LOG_ROOT}/desktop.log"
LAUNCHER_LOG="${LOG_ROOT}/launcher.log"

usage() {
  cat <<'EOF'
Usage:
  scripts/bb-dev-app main [--no-open]
      Fetch origin/main, switch this checkout to main, fast-forward, then start
      the source dev server and desktop shell.

  scripts/bb-dev-app branch <branch> [--no-open]
      Switch this checkout to a local branch, or create it from origin/<branch>,
      then start the source dev server and desktop shell.

  scripts/bb-dev-app current [--no-open]
      Start the source dev server and desktop shell for the current branch.

  scripts/bb-dev-app stop
      Stop the launcher-managed dev server and desktop shell.

  scripts/bb-dev-app status
      Print branch, ports, process status, and useful URLs.

  scripts/bb-dev-app env
      Print shell exports for using pnpm bb:dev against this dev instance.

  scripts/bb-dev-app logs [dev|desktop|launcher]
      Follow launcher logs. Defaults to the dev server log.
EOF
}

log() {
  mkdir -p "${LOG_ROOT}"
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" \
    | tee -a "${LAUNCHER_LOG}" >&2
}

die() {
  log "ERROR: $*"
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

ensure_repo() {
  # Accept both a normal checkout (.git directory) and a linked worktree
  # (.git is a file pointing at the common git dir).
  [[ -e "${REPO_ROOT}/.git" ]] || die "Repo not found: ${REPO_ROOT}"
}

load_config() {
  local config
  config="$(
    node - "${REPO_ROOT}" <<'NODE'
const crypto = require("node:crypto");
const os = require("node:os");
const path = require("node:path");

const repoRoot = path.resolve(process.argv[2]);
const homeDir = os.homedir();
const hash = crypto.createHash("sha256").update(repoRoot).digest("hex");
const homeRelativePath = path.relative(homeDir, repoRoot);
const label =
  homeRelativePath.length > 0 &&
  !homeRelativePath.startsWith("../") &&
  !homeRelativePath.startsWith("..\\") &&
  homeRelativePath !== ".." &&
  !path.isAbsolute(homeRelativePath)
    ? homeRelativePath
    : repoRoot;
const sanitized =
  label
    .toLowerCase()
    .replace(/[^a-z0-9._-]+/gu, "-")
    .replace(/^[._-]+|[._-]+$/gu, "") || "worktree";
const offset = Number.parseInt(hash.slice(0, 8), 16) % 8000;
const instanceId = `${sanitized}-${hash.slice(0, 12)}`;
const dataDir = path.join(homeDir, ".bb-dev", instanceId);
const values = {
  BB_DEV_APP_PORT: 11000 + offset,
  BB_DEV_ENV_PORT: 43000 + offset,
  BB_HOST_DAEMON_PORT: 27000 + offset,
  BB_SERVER_PORT: 19000 + offset,
  BB_SERVER_URL: `http://localhost:${19000 + offset}`,
  DATA_DIR: dataDir,
  DESKTOP_USER_DATA_DIR: path.join(dataDir, "desktop"),
  INSTANCE_ID: instanceId,
};
for (const [key, value] of Object.entries(values)) {
  console.log(`${key}=${JSON.stringify(String(value))}`);
}
NODE
  )"
  eval "${config}"
}

screen_session_exists() {
  local session="$1"
  local listing
  listing="$(screen -ls 2>/dev/null || true)"
  awk -v session=".${session}" 'index($0, session) > 0 { found = 1 } END { exit found ? 0 : 1 }' <<<"${listing}"
}

quit_screen_session() {
  local session="$1"
  if screen_session_exists "${session}"; then
    log "Stopping screen session ${session}"
    screen -S "${session}" -X quit || true
  fi
}

kill_pid_list() {
  local signal="$1"
  shift
  local pids=("$@")
  (( ${#pids[@]} == 0 )) && return 0
  /bin/kill "-${signal}" "${pids[@]}" 2>/dev/null || true
}

port_listener_pids() {
  local port="$1"
  lsof -nP -tiTCP:"${port}" -sTCP:LISTEN 2>/dev/null | sort -u || true
}

desktop_pids() {
  ps -axo pid=,command= \
    | awk -v user_data="--user-data-dir=${DESKTOP_USER_DATA_DIR}" '
        index($0, user_data) > 0 { print $1 }
      ' \
    | sort -u
}

stop_dev_app() {
  load_config

  quit_screen_session "${DESKTOP_SESSION}"
  quit_screen_session "${DEV_SESSION}"

  sleep 2

  local pids=()
  pids+=("${(@f)$(port_listener_pids "${BB_DEV_APP_PORT}")}")
  pids+=("${(@f)$(port_listener_pids "${BB_SERVER_PORT}")}")
  pids+=("${(@f)$(port_listener_pids "${BB_HOST_DAEMON_PORT}")}")
  pids+=("${(@f)$(port_listener_pids "${BB_DEV_ENV_PORT}")}")
  pids+=("${(@f)$(desktop_pids)}")
  pids=("${(@u)pids}")

  if (( ${#pids[@]} > 0 )); then
    log "Stopping remaining dev-instance processes: ${pids[*]}"
    kill_pid_list TERM "${pids[@]}"
    sleep 2
    kill_pid_list KILL "${pids[@]}"
  fi
}

handle_dirty_work_before_branch_switch() {
  if [[ -z "$(git -C "${REPO_ROOT}" status --porcelain)" ]]; then
    return
  fi

  if [[ "${BB_DEV_APP_STASH_DIRTY:-0}" != "1" ]]; then
    log "Leaving dirty checkout in place before branch switch; git will stop if files conflict"
    return
  fi

  local stash_msg="bb-dev-app-auto-stash-$(date '+%Y%m%d-%H%M%S')"
  log "Stashing dirty checkout before branch switch: ${stash_msg}"
  git -C "${REPO_ROOT}" stash push -u -m "${stash_msg}" >/dev/null
}

switch_to_main() {
  stop_dev_app
  handle_dirty_work_before_branch_switch
  log "Fetching origin/main"
  git -C "${REPO_ROOT}" fetch origin main
  log "Switching to main"
  git -C "${REPO_ROOT}" switch main
  log "Fast-forwarding main from origin/main"
  git -C "${REPO_ROOT}" pull --ff-only origin main
}

switch_to_branch() {
  local branch="$1"
  [[ -n "${branch}" ]] || die "Branch name is required"
  [[ "${branch}" != "--no-open" ]] || die "Branch name is required"

  stop_dev_app
  handle_dirty_work_before_branch_switch
  log "Fetching origin"
  git -C "${REPO_ROOT}" fetch origin
  if git -C "${REPO_ROOT}" show-ref --verify --quiet "refs/heads/${branch}"; then
    log "Switching to local branch ${branch}"
    git -C "${REPO_ROOT}" switch "${branch}"
  elif git -C "${REPO_ROOT}" show-ref --verify --quiet "refs/remotes/origin/${branch}"; then
    log "Creating local branch ${branch} from origin/${branch}"
    git -C "${REPO_ROOT}" switch --track -c "${branch}" "origin/${branch}"
  else
    log "Switching to branch ${branch}"
    git -C "${REPO_ROOT}" switch "${branch}"
  fi
  if git -C "${REPO_ROOT}" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    log "Fast-forwarding ${branch} from its upstream"
    git -C "${REPO_ROOT}" pull --ff-only
  fi
}

ensure_dependencies() {
  log "Installing workspace dependencies"
  pnpm -C "${REPO_ROOT}" install --frozen-lockfile

  log "Checking native Node modules"
  node "${REPO_ROOT}/scripts/ensure-native-modules.mjs"

  if ! (cd "${REPO_ROOT}/apps/desktop" && node -e "require('electron')" >/dev/null 2>&1); then
    local electron_install
    electron_install="$(
      find "${REPO_ROOT}/node_modules/.pnpm" -path '*/node_modules/electron/install.js' -type f -print -quit
    )"
    [[ -n "${electron_install}" ]] || die "Could not find Electron install.js"
    log "Installing Electron runtime"
    node "${electron_install}"
  fi
}

wait_for_log_pattern() {
  local file="$1"
  local pattern="$2"
  local label="$3"
  local timeout_seconds="$4"
  local elapsed=0
  while (( elapsed < timeout_seconds )); do
    if [[ -f "${file}" ]] && grep -q "${pattern}" "${file}"; then
      return 0
    fi
    if [[ -f "${file}" ]] && grep -q "port .* is unavailable\\|ELIFECYCLE\\|ERROR  run failed" "${file}"; then
      die "${label} failed; see ${file}"
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done
  die "Timed out waiting for ${label}; see ${file}"
}

start_dev_server() {
  log "Starting dev server session ${DEV_SESSION}"
  rm -f "${DEV_LOG}"
  screen -dmS "${DEV_SESSION}" /bin/zsh -lc "cd ${(q)REPO_ROOT} && export PATH=${(q)PATH} && exec pnpm dev > ${(q)DEV_LOG} 2>&1"
  wait_for_log_pattern "${DEV_LOG}" "Host daemon started" "dev server" 90
}

start_desktop() {
  log "Starting desktop session ${DESKTOP_SESSION}"
  rm -f "${DESKTOP_LOG}"
  screen -dmS "${DESKTOP_SESSION}" /bin/zsh -lc "cd ${(q)REPO_ROOT} && export PATH=${(q)PATH} && exec pnpm exec turbo run dev --filter=@bb/desktop > ${(q)DESKTOP_LOG} 2>&1"
  wait_for_log_pattern "${DESKTOP_LOG}" "@bb/desktop: app http://localhost:${BB_DEV_APP_PORT}" "desktop app" 120
}

open_app_url() {
  /usr/bin/open "http://localhost:${BB_DEV_APP_PORT}" >/dev/null 2>&1 || true
}

start_current() {
  local open_after_start="$1"
  stop_dev_app
  ensure_dependencies
  load_config
  start_dev_server
  start_desktop
  [[ "${open_after_start}" == "1" ]] && open_app_url
  status
}

status() {
  load_config
  local branch head codex_version
  branch="$(git -C "${REPO_ROOT}" branch --show-current 2>/dev/null || true)"
  head="$(git -C "${REPO_ROOT}" rev-parse --short HEAD 2>/dev/null || true)"
  codex_version="$(codex --version 2>/dev/null || true)"

  printf 'Repo: %s\n' "${REPO_ROOT}"
  printf 'Branch: %s (%s)\n' "${branch:-detached}" "${head:-unknown}"
  printf 'Codex: %s\n' "${codex_version:-not found}"
  printf 'Instance: %s\n' "${INSTANCE_ID}"
  printf 'Data dir: %s\n' "${DATA_DIR}"
  printf 'App: http://localhost:%s\n' "${BB_DEV_APP_PORT}"
  printf 'Server: %s\n' "${BB_SERVER_URL}"
  printf 'Host daemon: http://127.0.0.1:%s\n' "${BB_HOST_DAEMON_PORT}"
  printf 'Dev-env: http://127.0.0.1:%s\n' "${BB_DEV_ENV_PORT}"
  printf 'Desktop user data: %s\n' "${DESKTOP_USER_DATA_DIR}"
  printf 'Dev session: %s\n' "$(screen_session_exists "${DEV_SESSION}" && echo running || echo stopped)"
  printf 'Desktop session: %s\n' "$(screen_session_exists "${DESKTOP_SESSION}" && echo running || echo stopped)"
  printf 'Logs: %s, %s\n' "${DEV_LOG}" "${DESKTOP_LOG}"
}

print_env() {
  load_config
  cat <<EOF
export BB_SERVER_URL=${BB_SERVER_URL}
export BB_HOST_DAEMON_PORT=${BB_HOST_DAEMON_PORT}
export BB_PROJECT_ID=proj_personal
unset BB_THREAD_ID
EOF
}

follow_logs() {
  local target="${1:-dev}"
  case "${target}" in
    dev) tail -f "${DEV_LOG}" ;;
    desktop) tail -f "${DESKTOP_LOG}" ;;
    launcher) tail -f "${LAUNCHER_LOG}" ;;
    *) die "Unknown log target: ${target}" ;;
  esac
}

main() {
  require_command git
  require_command node
  require_command pnpm
  require_command screen
  require_command lsof
  ensure_repo
  mkdir -p "${LOG_ROOT}"

  local command="${1:-}"
  local open_after_start="1"
  case "${2:-}" in
    --no-open) open_after_start="0" ;;
  esac
  case "${3:-}" in
    --no-open) open_after_start="0" ;;
  esac

  case "${command}" in
    main)
      switch_to_main
      start_current "${open_after_start}"
      ;;
    branch)
      switch_to_branch "${2:-}"
      start_current "${open_after_start}"
      ;;
    current)
      start_current "${open_after_start}"
      ;;
    stop)
      stop_dev_app
      ;;
    status)
      status
      ;;
    env)
      print_env
      ;;
    logs)
      follow_logs "${2:-dev}"
      ;;
    help|-h|--help|"")
      usage
      ;;
    *)
      usage
      die "Unknown command: ${command}"
      ;;
  esac
}

main "$@"
